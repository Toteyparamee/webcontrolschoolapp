# ===========================
# API Configuration
# ===========================

# ตั้งเป็น 'true' เมื่อใช้ Kong Gateway (Production)
# ตั้งเป็น 'false' เมื่อเรียก Backend โดยตรง (Development)
VITE_USE_KONG=true

# Kong Gateway URL (ใช้เมื่อ USE_KONG=true)
VITE_KONG_GATEWAY_URL=http://localhost:30000

# Backend Services URLs (ใช้เมื่อ USE_KONG=false)
VITE_LOGIN_API_URL=http://localhost:8080
VITE_PERSONNEL_API_URL=http://localhost:8082

# ===========================
# วิธีการใช้งาน:
# ===========================
# Development (ไม่มี Kong): VITE_USE_KONG=false
# Production (ใช้ Kong):     VITE_USE_KONG=true
